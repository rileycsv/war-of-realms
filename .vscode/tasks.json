{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create bin Directory",
      "type": "shell",
      "command": "if not exist bin mkdir bin",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Compile Java Files",
      "type": "shell",
      "command": "C:\\Program Files\\Java\\jdk-25.0.2\\bin\\javac.exe",
      "args": [
        "-d", "bin",
        "-cp", "src;C:\\javafx-sdk-25.0.2\\lib\\*",
        "--module-path", "C:\\javafx-sdk-25.0.2\\lib\\",
        "--add-modules", "javafx.base,javafx.controls,javafx.fxml,javafx.graphics,javafx.media,javafx.swing,javafx.web",
        "-sourcepath", "src",
        "src/main/Main.java",
        "src/core/GameManager.java",
        "src/core/Player.java",
        "src/entities/Unit.java",
        "src/environment/Board.java",
        "src/environment/tile/Tile.java",
        "src/environment/tile/GrassTile.java",
        "src/environment/tile/MountainTile.java",
        "src/environment/tile/RiverTile.java",
        "src/environment/tile/VoidTile.java",
        "src/utils/Debug.java"
      ],
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "dependsOn": ["Create bin Directory"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$javac"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Run War of Realms",
      "type": "shell",
      "command": "C:\\Program Files\\Java\\jdk-25.0.2\\bin\\java.exe",
      "args": [
        "--module-path", "C:\\javafx-sdk-25.0.2\\lib\\",
        "--add-modules", "javafx.base,javafx.controls,javafx.fxml,javafx.graphics,javafx.media,javafx.swing,javafx.web",
        "-cp", "bin",
        "main.Main"
      ],
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "dependsOn": ["Compile Java Files"],
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}