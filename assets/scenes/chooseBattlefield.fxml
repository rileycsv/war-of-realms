<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="900.0" stylesheets="@../styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="battlefieldController">
   <children>
      <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" stylesheets="@../styles.css">
         <children>
            <Label layoutX="-3.0" text="Choose Your Battlefield" textAlignment="CENTER">
               <font>
                  <Font name="Blackadder ITC" size="72.0" />
               </font>
            </Label>
            <HBox layoutX="-54.0" layoutY="371.0" spacing="205.0">
               <children>
                  <Button fx:id="buttonEasy" mnemonicParsing="false" onAction="#chooseEasy" prefHeight="31.0" prefWidth="100.0" style="-fx-background-color: #333333;" text="Easy" textFill="WHITE">
                     <effect>
                        <DropShadow />
                     </effect>
                     <font>
                        <Font size="15.0" />
                     </font>
                  </Button>
                  <Button fx:id="buttonMedium" mnemonicParsing="false" onAction="#chooseMedium" prefHeight="31.0" prefWidth="100.0" style="-fx-background-color: #333333;" text="Medium" textFill="WHITE">
                     <effect>
                        <DropShadow />
                     </effect>
                     <font>
                        <Font size="15.0" />
                     </font>
                  </Button>
                  <Button fx:id="buttonHard" mnemonicParsing="false" onAction="#chooseHard" prefHeight="31.0" prefWidth="100.0" style="-fx-background-color: #333333;" text="Hard" textFill="WHITE">
                     <effect>
                        <DropShadow />
                     </effect>
                     <font>
                        <Font size="15.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <HBox layoutX="-124.0" layoutY="150.0" spacing="50.0">
               <children>
                  <ImageView fitHeight="210.0" fitWidth="250.0" pickOnBounds="true">
                     <image>
                        <Image url="@sceneImages/easy_level.png" />
                     </image>
                  </ImageView>
                  <ImageView fitHeight="210.0" fitWidth="250.0" pickOnBounds="true">
                     <image>
                        <Image url="@sceneImages/medium_level.png" />
                     </image>
                  </ImageView>
                  <ImageView fitHeight="210.0" fitWidth="250.0" pickOnBounds="true">
                     <image>
                        <Image url="@sceneImages/hard_level.png" />
                     </image>
                  </ImageView>
               </children>
            </HBox>
         </children>
      </AnchorPane>
   </children>
</StackPane>
